---
// Sticky top nav + global scroll behaviours (active-section spy, reveal-on-scroll).
import { navSections, CONTACT } from "../data/site.js";
---

<nav id="nav">
  <div class="wrap nav-inner">
    <a href="/" class="logo"><img class="logo-mark" src="/logo.png" alt="MicroApts logo" width="34" height="34" />MicroApts</a>
    <div class="nav-pill">
      {navSections.map((s) => <a href={s.href} data-nav={s.id}>{s.label}</a>)}
    </div>
    <a class="nav-call" href={`tel:${CONTACT.phone1.replace(/\s/g, "")}`}><i class="ti ti-phone"></i><span>{CONTACT.phone1}</span></a>
  </div>
</nav>

<script>
  /* Sticky nav border + hide-on-scroll-down / reveal-on-scroll-up.
     Header stays hidden over the full-screen hero and only appears when the
     user scrolls back up. */
  const nav = document.getElementById("nav");
  // Stay transparent while the dark hero is behind the nav; go solid once past it.
  // Pages without a hero (e.g. /gallery, /team) are always solid.
  const heroEl = document.querySelector(".hero");
  // Dark-themed sections behind the (transparent) nav — used to flip the logo /
  // call-link text colour so it stays readable over both light and dark sections.
  const darkSections = Array.from(document.querySelectorAll<HTMLElement>("[data-nav-dark]"));
  const NAV_PROBE_Y = 36; // y within the logo, in both top:14 and scrolled top:0 states
  let lastY = window.scrollY;
  const onNavScroll = () => {
    const y = window.scrollY;
    const overHero = heroEl ? heroEl.getBoundingClientRect().bottom > 80 : false;
    nav?.classList.toggle("scrolled", !overHero);
    // Light text over dark sections, dark text over light ones.
    const overDark = darkSections.some((s) => {
      const r = s.getBoundingClientRect();
      return r.top <= NAV_PROBE_Y && r.bottom > NAV_PROBE_Y;
    });
    nav?.classList.toggle("over-light", !overDark);
    // keep the header visible the whole time the hero is pinned; only after the
    // hero (sticky) is gone does it hide on scroll-down / show on scroll-up.
    if (overHero || y < 90 || y < lastY) nav?.classList.remove("nav-hidden");
    else nav?.classList.add("nav-hidden");
    // never pre-select a section while still over the hero
    if (overHero) document.querySelectorAll(".nav-pill a.active").forEach((l) => l.classList.remove("active"));
    lastY = y;
  };
  onNavScroll();
  addEventListener("scroll", onNavScroll, { passive: true });

  /* Active-section highlight */
  const navLinks = document.querySelectorAll("[data-nav]");

  /* On a sub-page (e.g. /gallery, /team) highlight that link directly —
     the scroll-spy below only applies to in-page anchors on the homepage. */
  const path = (location.pathname.replace(/\/+$/, "") || "/");
  navLinks.forEach((l) => {
    const href = l.getAttribute("href") || "";
    if (!href.includes("#") && href.replace(/\/+$/, "") === path) {
      l.classList.add("active");
    }
  });

  const spy = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        navLinks.forEach((l) =>
          l.classList.toggle("active", (l as HTMLElement).dataset.nav === e.target.id)
        );
      }
    });
  }, { rootMargin: "-45% 0px -50% 0px" });
  navLinks.forEach((l) => {
    const el = document.getElementById((l as HTMLElement).dataset.nav!);
    if (el) spy.observe(el);
  });

  /* Reveal-on-scroll for any .reveal element across the page.
     Belt-and-suspenders so a section can NEVER get stuck invisible (the bug
     where the partners section appeared "missing"):
       1. IntersectionObserver — reliably reveals in-view elements, including
          when a visitor lands directly on an anchor like #partners.
       2. A scroll/resize/rAF fallback in case an observer callback is missed
          on very fast scrolling.
       3. A final safety timer that force-reveals anything still hidden. */
  const reveal = (el) => el.classList.add("in");
  const els = Array.from(document.querySelectorAll(".reveal"));

  if ("IntersectionObserver" in window) {
    const io = new IntersectionObserver((entries, obs) => {
      entries.forEach((e) => { if (e.isIntersecting) { reveal(e.target); obs.unobserve(e.target); } });
    }, { threshold: 0.1 });
    els.forEach((el) => io.observe(el));
  } else {
    els.forEach(reveal);
  }

  const revealInView = () => {
    els.forEach((el) => {
      if (el.classList.contains("in")) return;
      const r = el.getBoundingClientRect();
      if (r.top < innerHeight * 0.92 && r.bottom > 0) reveal(el);
    });
  };
  revealInView();
  addEventListener("scroll", revealInView, { passive: true });
  addEventListener("resize", revealInView);
  addEventListener("load", () => {
    revealInView();
    let n = 0;
    const tick = () => { revealInView(); if (++n < 20) requestAnimationFrame(tick); };
    requestAnimationFrame(tick);
    // Last resort: never leave content permanently hidden.
    setTimeout(() => els.forEach((el) => {
      const r = el.getBoundingClientRect();
      if (r.top < innerHeight) reveal(el);
    }), 1800);
  });
</script>
