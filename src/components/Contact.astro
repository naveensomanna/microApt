---
import { CONTACT } from "../data/site.js";
---

<section class="sec-pad" id="contact">
  <div class="wrap">
    <div class="cta reveal">
      <div class="grid-c"></div>
      <div class="cta-inner">
        <div class="sec-tag cta-tag">Let's talk hardware</div>
        <h2>Tell us what you need.<br />We'll quote it within hours.</h2>
        <p>Whether it's 5 laptops or a 200-seat rollout, our team builds the right configuration for your budget and timeline.</p>
        <div class="cta-actions">
          <button class="btn-light" data-quote>Get a quote</button>
          <a href={`https://wa.me/${CONTACT.whatsapp}`} target="_blank" rel="noopener" class="btn-outline"><i class="ti ti-brand-whatsapp"></i> WhatsApp us</a>
        </div>
        <div class="cta-contacts">
          <span><i class="ti ti-map-pin"></i> {CONTACT.location}</span>
          <span><i class="ti ti-phone"></i> {CONTACT.phone1}</span>
          <span><i class="ti ti-phone"></i> {CONTACT.phone2}</span>
        </div>
      </div>
    </div>
  </div>
</section>
