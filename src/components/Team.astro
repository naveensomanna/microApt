---
import { team } from "../data/site.js";
---

<section id="team" class="sec-pad team-sec">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-tag">Our team</div>
      <h2>{team.total} people behind every deployment.</h2>
      <p class="sec-desc">A full in-house team across management, sales, technical and procurement — so sourcing, deployment and support all stay under one roof.</p>
    </div>

    <div class="team-grid reveal">
      {team.departments.map((d) => (
        <div class="team-dept">
          <div class="team-dept-head">
            <div class="team-dept-ico"><i class={`ti ti-${d.icon}`}></i></div>
            <div>
              <h3>{d.key}</h3>
              <span class="team-count">{d.count} {d.count === 1 ? "member" : "members"}</span>
            </div>
          </div>
          <p class="team-desc">{d.desc}</p>
          <div class="team-avatars">
            {d.members.map((m) => (
              <span class="team-av" title={m.role}>
                {m.photo
                  ? <img src={m.photo} alt={m.name || m.role} loading="lazy" />
                  : <i class="ti ti-user"></i>}
              </span>
            ))}
            {d.count > d.members.length && (
              <span class="team-av team-more">+{d.count - d.members.length}</span>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
