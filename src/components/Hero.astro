---
// Hero with the animated hardware-lifecycle loop and the stat bar.
import { lifecycle, stats } from "../data/site.js";
---

<header class="hero">
  <div class="hero-bg"></div>
  <div class="grid-bg"></div>
  <div class="wrap hero-inner">
    <div class="reveal">
      <div class="eyebrow"><span class="pulse"></span>Sale · Rentals · Service · AMC</div>
      <h1>We manage IT hardware<br />across its <span class="accent">entire life.</span></h1>
      <p class="hero-sub">From brand-new and certified-refurbished supply, to rental, onsite service, chip-level repair, AMC and buyback — MicroApts keeps corporate fleets running across India, on a budget that works.</p>
      <div class="hero-actions">
        <button class="btn-primary" data-quote>Get a quote within hours <i class="ti ti-arrow-right"></i></button>
        <a href="#products" class="btn-ghost">Explore catalog</a>
      </div>
      <div class="trust">
        <span><i class="ti ti-receipt"></i>GST invoice</span>
        <span><i class="ti ti-shield-check"></i>Warranty on every unit</span>
        <span><i class="ti ti-cpu"></i>Chip-level repair</span>
        <span><i class="ti ti-truck-delivery"></i>PAN India delivery</span>
      </div>
    </div>

    <div class="loop-wrap" id="loop">
      <svg class="loop-svg" viewBox="0 0 400 400" aria-hidden="true">
        <circle class="ring-track" cx="200" cy="200" r="150"></circle>
        <circle class="ring-prog" id="prog" cx="200" cy="200" r="150" transform="rotate(-90 200 200)"></circle>
        <circle class="hub-ring" cx="200" cy="200" r="74"></circle>
        <circle class="hub-ring" cx="200" cy="200" r="62"></circle>
        <circle class="hub" cx="200" cy="200" r="58"></circle>
        <foreignObject class="hub-fo" x="130" y="158" width="140" height="94">
          <div xmlns="http://www.w3.org/1999/xhtml" class="hub-inner">
            <div class="hub-power"><i class="ti ti-power"></i></div>
            <div class="hub-stage" id="hubStage">Sale</div>
            <div class="hub-tag" id="hubTag">NEW &amp; REFURBISHED</div>
          </div>
        </foreignObject>
      </svg>
    </div>
  </div>

  <div class="wrap">
    <div class="statbar reveal">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat-num">{s.num}<span>{s.sym}</span></div>
          <div class="stat-lbl">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</header>

<script define:vars={{ lifecycle }}>
  /* ---------- Lifecycle loop ---------- */
  const loop = document.getElementById("loop");
  const N = lifecycle.length, R = 150, cx = 200, cy = 200;
  const nodeEls = [];
  lifecycle.forEach((s, i) => {
    const ang = (-90 + (360 / N) * i) * Math.PI / 180;
    const x = cx + R * Math.cos(ang), y = cy + R * Math.sin(ang);
    const node = document.createElement("div");
    node.className = "loop-node";
    node.style.left = `calc(${(x / 400) * 100}% - 27px)`;
    node.style.top = `calc(${(y / 400) * 100}% - 27px)`;
    node.innerHTML = `<div class="node-ico"><i class="ti ti-${s.icon}"></i></div>`;
    const lbl = document.createElement("div");
    lbl.className = "node-lbl";
    lbl.textContent = s.label;
    const lx = cx + (R + 32) * Math.cos(ang), ly = cy + (R + 32) * Math.sin(ang);
    lbl.style.left = `${(lx / 400) * 100}%`;
    lbl.style.top = `${(ly / 400) * 100}%`;
    loop.appendChild(node); loop.appendChild(lbl);
    nodeEls.push({ ico: node.querySelector(".node-ico"), lbl });
  });
  const prog = document.getElementById("prog");
  const C = 2 * Math.PI * R;
  prog.style.strokeDasharray = C;
  prog.style.transition = "stroke-dashoffset 1.1s cubic-bezier(.4,0,.2,1)";
  const hubStage = document.getElementById("hubStage"), hubTag = document.getElementById("hubTag");
  let active = 0;
  function setActive(idx) {
    nodeEls.forEach(({ ico, lbl }, i) => { ico.classList.toggle("on", i === idx); lbl.classList.toggle("on", i === idx); });
    prog.style.strokeDashoffset = C * (1 - (idx + 1) / N);
    hubStage.textContent = lifecycle[idx].label;
    hubTag.textContent = lifecycle[idx].tag;
  }
  setActive(0);
  setInterval(() => { active = (active + 1) % N; setActive(active); }, 1600);
</script>
