---
// Pinned hero: the video stays fixed over a short scroll track while the stat
// cards reveal one-by-one as you scroll. Once all are in, the pin releases and
// the page scrolls on normally.
import { stats } from "../data/site.js";
---

<header class="hero">
  <div class="hero-sticky">
    <video class="hero-video" autoplay muted loop playsinline preload="auto" aria-hidden="true">
      <source src="/hero.webm" type="video/webm" />
      <source src="/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-scrim" aria-hidden="true"></div>

    <div class="wrap hero-inner">
      <div class="reveal">
        <div class="eyebrow"><span class="pulse"></span>Sale · Rentals · Service · Enterprise IT</div>
        <h1>We manage IT hardware<br />across its <span class="accent">entire life.</span></h1>
        <p class="hero-sub">From brand-new and certified-refurbished supply, to rental, onsite service, chip-level repair and enterprise IT solutions — MicroApts keeps corporate fleets running across India, on a budget that works.</p>
        <div class="hero-actions">
          <button class="btn-primary" data-quote>Get a quote within hours <i class="ti ti-arrow-right"></i></button>
          <a href="#products" class="btn-ghost">Explore catalog</a>
        </div>
        <div class="trust">
          <span><i class="ti ti-receipt"></i>GST invoice</span>
          <span><i class="ti ti-shield-check"></i>Warranty on every unit</span>
          <span><i class="ti ti-cpu"></i>Chip-level repair</span>
          <span><i class="ti ti-truck-delivery"></i>PAN India delivery</span>
        </div>
      </div>
    </div>

    <div class="hero-stats">
      <div class="wrap">
        <div class="statbar">
          {stats.map((s) => (
            <div class="stat">
              <div class="stat-num">{s.num}<span>{s.sym}</span></div>
              <div class="stat-lbl">{s.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Scroll-scrubbed reveal: map scroll progress through the hero's track to
  // showing the stat cards one after another. The sticky video unpins on its own
  // once the track ends (all cards visible).
  const hero = document.querySelector(".hero") as HTMLElement | null;
  const statbar = document.querySelector<HTMLElement>(".statbar");
  const cards = Array.from(document.querySelectorAll<HTMLElement>(".statbar .stat"));
  if (hero && statbar && cards.length) {
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (reduce) {
      statbar.classList.add("lit");
      cards.forEach((c) => c.classList.add("show"));
    } else {
      const n = cards.length;
      let ticking = false;
      const update = () => {
        ticking = false;
        const track = hero.offsetHeight - window.innerHeight;
        const p = track > 0 ? Math.min(1, Math.max(0, -hero.getBoundingClientRect().top / track)) : 1;
        // reveal the white card only once scrolling starts, then items one by one
        statbar.classList.toggle("lit", p >= 0.04);
        cards.forEach((c, i) => {
          const threshold = 0.06 + i * 0.2;
          c.classList.toggle("show", p >= threshold);
        });
      };
      addEventListener("scroll", () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } }, { passive: true });
      addEventListener("resize", update);
      update();
    }
  }
</script>
