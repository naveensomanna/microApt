---
// Hero with a full-bleed background video and the stat bar.
import { stats } from "../data/site.js";
---

<header class="hero">
  <!-- Full-bleed background video (optimised 1080p, muted, looping). -->
  <video class="hero-video" autoplay muted loop playsinline preload="auto" aria-hidden="true">
    <source src="/hero.webm" type="video/webm" />
    <source src="/hero.mp4" type="video/mp4" />
  </video>
  <div class="hero-scrim" aria-hidden="true"></div>
  <div class="wrap hero-inner">
    <div class="reveal">
      <div class="eyebrow"><span class="pulse"></span>Sale · Rentals · Service · AMC</div>
      <h1>We manage IT hardware<br />across its <span class="accent">entire life.</span></h1>
      <p class="hero-sub">From brand-new and certified-refurbished supply, to rental, onsite service, chip-level repair, AMC and buyback — MicroApts keeps corporate fleets running across India, on a budget that works.</p>
      <div class="hero-actions">
        <button class="btn-primary" data-quote>Get a quote within hours <i class="ti ti-arrow-right"></i></button>
        <a href="#products" class="btn-ghost">Explore catalog</a>
      </div>
      <div class="trust">
        <span><i class="ti ti-receipt"></i>GST invoice</span>
        <span><i class="ti ti-shield-check"></i>Warranty on every unit</span>
        <span><i class="ti ti-cpu"></i>Chip-level repair</span>
        <span><i class="ti ti-truck-delivery"></i>PAN India delivery</span>
      </div>
    </div>
  </div>

  <div class="wrap">
    <div class="statbar reveal">
      {stats.map((s) => (
        <div class="stat">
          <div class="stat-num">{s.num}<span>{s.sym}</span></div>
          <div class="stat-lbl">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</header>
