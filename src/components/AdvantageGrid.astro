---
// Why corporate teams choose us — standalone dark section.
// Self-contained: own palette (custom properties), scoped styles and a single
// IntersectionObserver for a staggered, reveal-once cascade. No global CSS, no
// animation libraries.

interface Advantage {
  title: string;
  desc: string;
}

// Single source of truth — edit copy here.
const advantages: Advantage[] = [
  {
    title: "Pan-India supply",
    desc: "Capability across multiple cities and states with logistics built for scale.",
  },
  {
    title: "Trusted since 2021",
    desc: "A registered company backed by a team with 15+ years of industry experience.",
  },
  {
    title: "B2B specialists",
    desc: "Deep focus on corporate, school and college procurement, with setup and installation.",
  },
  {
    title: "Quality assurance",
    desc: "Structured testing and recertification on every refurbished unit we ship.",
  },
  {
    title: "Engineer-backed",
    desc: "Skilled onsite and remote engineering team for service, repair and managed enterprise IT support.",
  },
  {
    title: "Warranty & replacement",
    desc: "Warranty-backed solutions with flexible replacement and dependable after-sales support.",
  },
];

const pad = (n: number) => String(n).padStart(2, "0");
---

<section class="ag" aria-labelledby="ag-title">
  <div class="ag-wrap">
    <header class="ag-head">
      <p class="ag-eyebrow">The MicroApts advantage</p>
      <h2 id="ag-title" class="ag-headline">Why corporate teams choose us.</h2>
    </header>

    <ul class="ag-grid" role="list">
      {advantages.map((a, i) => (
        <li class="ag-card" data-index={i}>
          <span class="ag-num" aria-hidden="true">{pad(i + 1)}</span>
          <h3 class="ag-card-title">{a.title}</h3>
          <p class="ag-card-desc">{a.desc}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .ag {
    /* Palette — local to this section, matches the dark hero. */
    --bg: #0a0d13;
    --accent: #e8a33d;
    --card: #141923;
    --card-hover: #181f2b;
    --text: #f4f6fa;
    --muted: #aab3c0;
    --line: rgba(255, 255, 255, 0.08);

    background: var(--bg);
    color: var(--text);
    padding-block: clamp(64px, 10vw, 120px);
    padding-inline: 0;
  }

  /* Horizontal gutters live on the wrap, vertical rhythm on the section —
     kept on separate elements so they never cancel each other out. */
  .ag-wrap {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(20px, 5vw, 32px);
  }

  .ag-head {
    max-width: 720px;
    margin-bottom: clamp(36px, 5vw, 56px);
  }

  .ag-eyebrow {
    margin: 0 0 14px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .ag-headline {
    margin: 0;
    font-size: clamp(1.9rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  /* 3 / 2 / 1 responsive grid. */
  .ag-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 900px) {
    .ag-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .ag-grid {
      grid-template-columns: 1fr;
    }
  }

  .ag-card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 30px 26px 28px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 16px;
    /* Reveal start state. */
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 0.5s cubic-bezier(0.2, 0.7, 0.2, 1),
      transform 0.4s cubic-bezier(0.2, 0.7, 0.2, 1),
      border-color 0.25s ease,
      background-color 0.25s ease;
  }

  .ag-card.is-in {
    opacity: 1;
    transform: none;
  }

  /* Subtle hover micro-interaction: slight lift + accent border. */
  .ag-card:hover {
    transform: translateY(-4px);
    background: var(--card-hover);
    border-color: rgba(232, 163, 61, 0.5);
  }

  /* Visible focus ring should a card ever become a link/focusable. */
  .ag-card:focus-within,
  .ag-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
  }

  /* Sequence indicator — large but quiet; warms to the accent on hover. */
  .ag-num {
    margin-bottom: 18px;
    font-size: clamp(2.4rem, 4vw, 3.1rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
    color: rgba(244, 246, 250, 0.14);
    transition: color 0.25s ease;
  }

  .ag-card:hover .ag-num {
    color: rgba(232, 163, 61, 0.85);
  }

  .ag-card-title {
    margin: 0 0 10px;
    font-size: 1.15rem;
    font-weight: 650;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .ag-card-desc {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--muted);
  }

  /* Reduced motion: show everything immediately, no transform/transition. */
  @media (prefers-reduced-motion: reduce) {
    .ag-card {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .ag-card:hover {
      transform: none;
    }
  }
</style>

<script>
  // Staggered reveal-once. Plain IntersectionObserver — no scroll-jacking.
  const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
  const cards = Array.from(document.querySelectorAll<HTMLElement>(".ag .ag-card"));

  if (reduce || !("IntersectionObserver" in window)) {
    cards.forEach((c) => c.classList.add("is-in"));
  } else {
    const io = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const i = Number(el.dataset.index ?? 0);
          // Stagger by the card's place in the sequence (~80ms apart).
          el.style.transitionDelay = `${i * 80}ms`;
          el.classList.add("is-in");
          // Drop the delay once revealed so hover stays snappy.
          el.addEventListener(
            "transitionend",
            () => {
              el.style.transitionDelay = "";
            },
            { once: true },
          );
          obs.unobserve(el);
        });
      },
      { threshold: 0.18, rootMargin: "0px 0px -8% 0px" },
    );
    cards.forEach((c) => io.observe(c));
  }
</script>
