---
import { coreServices } from "../data/site.js";

const [feature, ...rest] = coreServices;
---

<section id="services" class="sec-pad">
  <div class="wrap">
    <div class="sec-head reveal">
      <div class="sec-tag">What we do</div>
      <h2>One partner for the full hardware lifecycle.</h2>
      <p class="sec-desc">From procurement to deployment to ongoing maintenance — we cover every stage so your team can focus on the work, not the infrastructure.</p>
    </div>
    <div class="svc-bento reveal">
      <div class="svc svc-feature" style={`background-image:url(${feature.img})`}>
        <div class="svc-body">
          <h3>{feature.title}</h3>
          <p>{feature.desc}</p>
        </div>
      </div>
      {rest.map((s) => (
        <div class="svc" style={`background-image:url(${s.img})`}>
          <div class="svc-body">
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
